{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Config for Barbapapazes",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":labels(dependencies, chore)",
    ":maintainLockFilesWeekly",
    ":semanticCommitTypeAll(chore)",
    "helpers:pinGitHubActionDigests"
  ],
  "prCreation": "not-pending",
  "dependencyDashboard": true,
  "meteor": {
    "enabled": false
  },
  "rangeStrategy": "bump",
  "npm": {
    "commitMessageTopic": "{{prettyDepType}} {{depName}}"
  },
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "schedule": ["on Monday"],
  "packageRules": [
    {
      "groupName": "composer packages",
      "groupSlug": "composer",
      "matchDatasources": [
        "packagist"
      ]
    },
    {
      "groupName": "npm packages",
      "groupSlug": "npm",
      "matchDatasources": [
        "npm"
      ]
    },
    {
      "description": "Do not automerge npm 0.x packages",
      "matchDatasources": ["npm"],
      "matchCurrentVersion": "/^0\\./",
      "automerge": false
    },
    {
      "description": "Do not automerge composer 0.x packages",
      "matchDatasources": ["packagist"],
      "matchCurrentVersion": "/^0\\./",
      "automerge": false
    },
    {
      "description": "Automerge non-major npm updates (patch/minor/pin/digest)",
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["patch", "minor", "pin", "digest"],
      "matchCurrentVersion": "!/^[0]\\./",
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": false,
      "prCreation": "not-pending"
    },
    {
      "description": "Automerge non-major composer updates (patch/minor/pin/digest)",
      "matchDatasources": ["packagist"],
      "matchUpdateTypes": ["patch", "minor", "pin", "digest"],
      "matchCurrentVersion": "!/^[0]\\./",
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": false,
      "prCreation": "not-pending"
    },
    {
      "groupName": "github actions",
      "groupSlug": "github-actions",
      "matchDatasources": [
        "github-tags"
      ]
    },
    {
      "groupName": "engines",
      "groupSlug": "engines",
      "matchDepTypes": [
        "engines"
      ]
    }
  ]
}
